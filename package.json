{
  "name": "book-crawler",
  "version": "2.0.0",
  "description": "书籍爬虫工具 - 通过Google搜索69shuba.com书籍并爬取内容 (Node.js版)",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch server.js",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:all": "node -e \"const{spawn}=require('child_process');spawn('node',['--watch','server.js'],{stdio:'inherit',shell:true});spawn('npm',['run','dev'],{cwd:'frontend',stdio:'inherit',shell:true})\"",
    "start": "node server.js",
    "build:frontend": "cd frontend && npm run build"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "cheerio": "^1.0.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "mongodb": "^6.9.0",
    "mysql2": "^3.11.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
